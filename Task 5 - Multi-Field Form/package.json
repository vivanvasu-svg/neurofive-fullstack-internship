{
    "name": "brew-haven-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "client": "npm run dev --prefix client",
        "server": "npm run dev --prefix server",
        "dev": "concurrently \"npm run client\" \"npm run server\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}